{
  "name": "llmbda-ts",
  "version": "0.1.0",
  "description": "A TypeScript reference implementation of the LLMbda calculus (Garby, Gordon, Sands 2026) — a labeled, dynamically information-flow-tracked lambda calculus for agentic LLM programs. NOT a proof: the noninterference theorem (TIPNI) is machine-checked only in the paper's Lean development. This port re-implements the operational semantics and tests the security-critical rules against the paper's own leak examples, but carries no formal guarantee.",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx test/run.ts",
    "coverage": "c8 --all --src src --include \"src/**/*.ts\" --exclude \"test/**\" --exclude \"examples/**\" --reporter text --reporter html --reporter json-summary node --import tsx test/run.ts",
    "example:postcode": "node --import tsx examples/postcode.ts",
    "example:retry": "node --import tsx examples/retry-loop.ts",
    "example:leak": "node --import tsx examples/fenton-denning-leak.ts",
    "example:confinement": "node --import tsx examples/var-pc-confinement.ts",
    "example:quarantine": "node --import tsx examples/quarantine-classify.ts",
    "example:robust-endorse": "node --import tsx examples/robust-endorse-cascade.ts",
    "example:endorse": "node --import tsx examples/endorse.ts",
    "example:camel-provenance": "node --import tsx examples/camel-provenance-quarantine.ts",
    "example:dynamic-label": "node --import tsx examples/dynamic-label.ts",
    "example:clear-isolation": "node --import tsx examples/clear-isolation.ts",
    "example:deep-label-confinement": "node --import tsx examples/deep-label-confinement.ts",
    "example:prim-wrap-values": "node --import tsx examples/prim-wrap-values.ts",
    "example:recv-scope-isolation": "node --import tsx examples/recv-scope-isolation.ts",
    "example:binop-prim-consistency": "node --import tsx examples/binop-prim-consistency.ts",
    "example:camel-readers-flowsto": "node --import tsx examples/camel-readers-flowsto.ts",
    "example:missing-binops": "node --import tsx examples/missing-binops.ts"
  },
  "devDependencies": {
    "c8": "^12.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
